{
  "manifest_version": 3,
  "name": "Tweet Collector Window",
  "version": "1.0.0",
  "description": "Collect tweets and show them in an on-page window.",
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.mailgun.net/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_title": "Tweet Collector",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
